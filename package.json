{
    "name": "silverstripe-contacts",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build:js": "rollup -c",
        "build:css": "sass client/admin/src/scss/ss-contacts.scss client/admin/dist/bundle.css --no-source-map",
        "build": "npm run build:js && npm run build:css",
        "watch:js": "rollup -c --watch",
        "watch:css": "sass --watch client/admin/src/scss/ss-contacts.scss client/admin/dist/bundle.css --no-source-map",
        "watch": "npm run watch:js & npm run watch:css"
    },
    "devDependencies": {
        "rollup": "^4.0.0",
        "sass": "^1.0.0"
    }
}
